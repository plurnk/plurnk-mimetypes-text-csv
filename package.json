{
    "name": "@plurnk/plurnk-mimetypes-text-csv",
    "version": "0.4.4",
    "description": "text/csv mimetype handler for plurnk-service. Homebrew RFC 4180 tokenizer; no parser dependency.",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=26"
    },
    "plurnk": {
        "kind": "mimetype",
        "handlers": [
            {
                "name": "text/csv",
                "glyph": "📊",
                "extensions": [
                    ".csv"
                ]
            }
        ]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "README.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/**/*.test.ts",
        "test": "npm run test:lint && npm run test:unit",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "prepare": "npm run build"
    },
    "devDependencies": {
        "@plurnk/plurnk-mimetypes": "0.15.28",
        "@types/node": "^26.0.0",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "@plurnk/plurnk-mimetypes": "^0.15.0"
    }
}
